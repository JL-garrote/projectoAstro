---
import "../global.css";
---

<div class="outer-wrapper">
  <div class="card">
    <div class="accent-bar"></div>

    <h2 class="title">Transmission</h2>

    <form id="transmission-form" class="form">
      <div class="field">
        <label class="label" for="name">Nombre del Operador</label>
        <input
          class="input"
          id="name"
          name="from_name"
          placeholder="John Doe"
          required
          type="text"
        />
      </div>

      <div class="field">
        <label class="label" for="email">Correo Electrónico</label>
        <input
          class="input"
          id="email"
          name="from_email"
          placeholder="john@example.com"
          required
          type="email"
        />
      </div>

      <div class="field">
        <label class="label" for="message">Descripción</label>
        <textarea
          class="input textarea custom-scrollbar"
          id="message"
          name="message"
          placeholder="Briefly describe your project or collaboration opportunity..."
          required
          rows="5"></textarea>
      </div>

      <button class="btn glow-btn" type="submit">ENVIAR</button>
    </form>
  </div>
</div>

<style>
  /* ── Outer wrapper with dark grid background ── */
  .outer-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 2rem;
    background-color: #0f1110;
    background-image:
      linear-gradient(rgba(0, 255, 156, 0.07) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 255, 156, 0.07) 1px, transparent 1px);
    background-size: 32px 32px;
    font-family: "JetBrains Mono", "Fira Mono", "Courier New", monospace;
  }

  /* ── Card ── */
  .card {
    position: relative;
    background-color: #1a1c1c;
    border: 1px solid #232d25;
    padding: 2rem 2.2rem;
    max-width: 480px;
    width: 100%;
    color: white;
    overflow: hidden;
  }

  /* ── Left accent bar ── */
  .accent-bar {
    position: absolute;
    top: 0;
    left: 0;
    width: 2px;
    height: 100%;
    background-color: #00ff9c;
    opacity: 0.6;
  }

  /* ── Title ── */
  .title {
    font-size: 1.65rem;
    font-weight: 600;
    color: #f3fff3;
    margin: 0 0 1.4rem 0;
    padding-bottom: 1rem;
    border-bottom: 1px solid #232d25;
    letter-spacing: 0.04em;
    font-family: inherit;
  }

  /* ── Form ── */
  .form {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
  }

  /* ── Field ── */
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  /* ── Labels ── */
  .label {
    font-size: 10px;
    color: #849587;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 600;
    font-family: inherit;
    transition: color 0.2s;
  }

  .label.active {
    color: #00ff9c;
  }

  /* ── Inputs & Textarea ── */
  .input {
    width: 100%;
    box-sizing: border-box;
    background-color: #121414;
    border: 1px solid #232d25;
    color: #b9cbbc;
    font-family: inherit;
    font-size: 0.82rem;
    padding: 0.7rem 1rem;
    outline: none;
    border-radius: 0;
    transition: border-color 0.2s;
    display: block;
  }

  .input::placeholder {
    color: rgba(132, 149, 135, 0.4);
  }

  .input:focus {
    border-color: #00ff9c;
  }

  .textarea {
    resize: none;
  }

  /* ── Button ── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    background-color: #00ff9c;
    color: #00391f;
    padding: 0.7rem 1.4rem;
    font-family: inherit;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    border: none;
    border-radius: 0;
    cursor: pointer;
    transition:
      opacity 0.15s,
      transform 0.1s;
    width: fit-content;
  }

  .btn:hover {
    opacity: 0.9;
  }

  .btn:active {
    transform: scale(0.97);
  }

  .glow-btn {
    box-shadow: 0 0 14px rgba(0, 255, 156, 0.45);
  }

  .arrow-icon {
    font-size: 17px;
    font-weight: 700;
    transition: transform 0.2s;
  }

  .btn:hover .arrow-icon {
    transform: translateX(3px);
  }

  /* ── Custom scrollbar ── */
  .custom-scrollbar::-webkit-scrollbar {
    width: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: #121414;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: #3b4b3f;
  }
</style>

<!-- Material Symbols for the arrow icon -->
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@18,700,0,0"
/>
<script
  type="text/javascript"
  src="https://cdn.jsdelivr.net/npm/@emailjs/browser@3/dist/email.min.js"
></script>

<script type="text/javascript">
  // Public Key: found in EmailJS dashboard → Account → API Keys
  emailjs.init("l4-yuFeM2N6y-3qRj");
</script>

<script type="text/javascript">
  const serviceID = "service_9smuobg";
  const templateID = "template_ktjilop";

  const form = document.getElementById("transmission-form");

  form.addEventListener("submit", function (event) {
    event.preventDefault();

    const templateParams = {
      from_name: document.getElementById("name").value,
      from_email: document.getElementById("email").value,
      message: document.getElementById("message").value,
      reply_to: document.getElementById("email").value,
    };

    emailjs.send(serviceID, templateID, templateParams).then(
      function () {
        alert("¡Correo enviado con éxito!");
        form.reset();
      },
      function (err) {
        alert("Hubo un error al enviar: " + JSON.stringify(err));
      }
    );
  });

  // Label highlight on focus
  document.querySelectorAll("input, textarea").forEach(function (el) {
    const label = el.closest(".field")?.querySelector(".label");
    el.addEventListener("focus", function () { label?.classList.add("active"); });
    el.addEventListener("blur", function () { label?.classList.remove("active"); });
  });
</script>
