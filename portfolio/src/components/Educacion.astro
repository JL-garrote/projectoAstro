<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursor-ring"></div>
<div class="scanline" id="scanline"></div>
<div class="noise"></div>

<section id="hero" class="hero-container">
    <!-- COLUMNA IZQUIERDA: EXPERIENCIA -->
    <div class="col">
        <h2 class="section-title">Experiencia</h2>

        <div class="entry">
            <div class="entry-marker"></div>
            <div class="entry-body">
                <div class="entry-top">
                    <h3 class="entry-role">Desarrollador Full Stack</h3>
                    <span class="entry-date">3 meses — PRESENCIAL.</span>
                </div>
                <p class="entry-company">Elenco Ahorro - Mairena del Aljarafe</p>
                <p class="entry-desc">
                    Desarrollo de aplicaciones web. Mas especifico un CRM completo para una consultoría energética.
                    Implementación de APIs REST y gestión de bases de
                    datos relacionales.
                </p>
            </div>
        </div>

        <div class="entry">
            <div class="entry-marker"></div>
            <div class="entry-body">
                <div class="entry-top">
                    <h3 class="entry-role">Técnico de Sistemas</h3>
                    <span class="entry-date">3 meses — PRESENCIAL.</span>
                </div>
                <p class="entry-company">Axona.SLR - Pavia (Italia)</p>
                <p class="entry-desc">
                    Mantenimiento y administración de infraestructura de red.
                    Soporte técnico a usuarios y gestión de incidencias.
                    Mantenimiento de sistemas informáticos y servidores locales.
                </p>
            </div>
        </div>
    </div>

    <!-- COLUMNA DERECHA: EDUCACIÓN -->
    <div class="col">
        <h2 class="section-title">Educación</h2>

        <div class="entry">
            <div class="entry-marker"></div>
            <div class="entry-body">
                <div class="entry-top">
                    <h3 class="entry-role">
                        Desarrollo de Aplicaciones Multiplataforma
                    </h3>
                    <span class="entry-date">2024 — 2026</span>
                </div>
                <p class="entry-company">
                    CFGS — FORMACIÓN PROFESIONAL DE GRADO SUPERIOR
                </p>
                <p class="entry-desc">
                    Formación en desarrollo de aplicaciones multiplataforma.
                    Especialización en tecnologías Java, Kotlin y desarrollo
                    móvil.
                </p>
            </div>
        </div>

        <div class="entry">
            <div class="entry-marker"></div>
            <div class="entry-body">
                <div class="entry-top">
                    <h3 class="entry-role">
                        Técnico en Sistemas Microinformáticos y Redes
                    </h3>
                    <span class="entry-date">2021 — 2023</span>
                </div>
                <p class="entry-company">
                    CFGM — FORMACIÓN PROFESIONAL DE GRADO MEDIO
                </p>
